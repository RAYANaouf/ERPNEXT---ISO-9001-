  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "submit": 1, "cancel": 1, "amend": 1, "print": 1
    },
    {
      "role": "Department User",
      "read": 1, "write": 1, "create": 1, "print": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ],

  "title_field": "report_month",
  "sort_field": "report_date",
