      "fieldtype": "Small Text"
    },
    {
      "fieldname": "commercial_signatory",
      "label": "Commercial Manager Signature",
      "fieldtype": "Link",
      "options": "User"
    },
    {
      "fieldname": "commercial_sign_date",
      "label": "Commercial Sign Date",
      "fieldtype": "Date"
    },


    {
      "fieldname": "section_purchases",
      "label": "Purchases",
      "fieldtype": "Section Break",
      "collapsible": 1
