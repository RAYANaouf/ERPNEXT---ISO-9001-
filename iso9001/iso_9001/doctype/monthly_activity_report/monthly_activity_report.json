{
  "name": "Monthly Activity Report",
  "doctype": "DocType",
  "module": "Custom",
  "custom": 1,
  "is_submittable": 1,
  "track_changes": 1,
  "document_type": "Document",
  "description": "Monthly Activity Report covering all departments: Commercial, Purchases, Stock, IT, HR, and General Management.",
  "fields": [


    {
      "fieldname": "report_month",
      "label": "Report Month",
      "fieldtype": "Data",
      "reqd": 1,
      "in_list_view": 1,
      "description": "e.g. January 2026"
    },
    {
      "fieldname": "report_date",
      "label": "Report Preparation Date",
      "fieldtype": "Date",
      "reqd": 1,
      "default": "Today"
    },
    {
      "fieldname": "prepared_by",
      "label": "Prepared By",
      "fieldtype": "Link",
      "options": "User",
      "reqd": 1
    },
    {
      "fieldname": "report_objective",
      "label": "Report Objective",
      "fieldtype": "Small Text",
      "default": "This report presents a comprehensive summary of the company's activities during the relevant month, highlighting key achievements, operational indicators, recorded difficulties, and proposed corrective measures across all main company operations."
    },

  
    {
      "fieldname": "section_commercial",
      "label": "Commercial Activity",
      "fieldtype": "Section Break",
      "collapsible": 0
    },

  
    {
      "fieldname": "sales_heading",
      "label": "Sales",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "revenue_vs_target",
      "label": "Revenue vs Target",
      "fieldtype": "Select",
      "options": "\nIncrease\nStable\nDecrease",
      "reqd": 1
    },
    {
      "fieldname": "success_rate",
      "label": "Success Rate (%)",
      "fieldtype": "Float",
      "description": "Percentage of target achieved"
    },


    {
      "fieldname": "col_customers",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "active_customers",
      "label": "Active Customers",
      "fieldtype": "Int"
    },
    {
      "fieldname": "new_customers",
      "label": "New Customers",
      "fieldtype": "Int"
    },


    {
      "fieldname": "section_marketing",
      "label": "Marketing & Commercial Relations",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "commercial_offers",
      "label": "Commercial Offers Submitted",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "field_visits_meetings",
      "label": "Field Visits / Meetings",
      "fieldtype": "Small Text"
