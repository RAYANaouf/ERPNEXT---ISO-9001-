{
  "doctype": "DocType",
  "name": "Opportunity Assessment Item",
  "module": "ISO 9001",
  "istable": 1,
  "editable_grid": 1,
  "engine": "InnoDB",
  "field_order": [
    "opp_description", "opp_owner", "action_plan",
    "likelihood", "potential_benefit", "priority_score", "priority_level",
    "target_date", "status"
  ],
  "fields": [
    { "fieldname": "opp_description", "fieldtype": "Small Text",  "label": "Opportunity Description", "in_list_view": 1, "reqd": 1, "columns": 3 },
    { "fieldname": "opp_owner",       "fieldtype": "Data",        "label": "Opportunity Owner",        "in_list_view": 1, "columns": 2 },
    { "fieldname": "action_plan",     "fieldtype": "Small Text",  "label": "Action Plan" },
    { "fieldname": "likelihood",       "fieldtype": "Select", "label": "Likelihood", "options": "Very Low\nLow\nMedium\nHigh\nVery High", "in_list_view": 1, "columns": 1 },
    { "fieldname": "potential_benefit","fieldtype": "Select", "label": "Benefit",    "options": "Very Low\nLow\nMedium\nHigh\nVery High", "in_list_view": 1, "columns": 1 },
    { "fieldname": "priority_level",  "fieldtype": "Data",        "label": "Priority",        "read_only": 1, "in_list_view": 1, "columns": 1 },
    { "fieldname": "target_date",     "fieldtype": "Date",        "label": "Target Date",     "in_list_view": 1, "columns": 1 },
    { "fieldname": "status",          "fieldtype": "Select",      "label": "Status", "options": "New\nIn Progress\nDone", "in_list_view": 1, "columns": 1 }
  ]
}